# === AFFILIATE LINKS (replace with YOUR referral URLs) ===
NEXT_PUBLIC_BITUNIX_AFFILIATE_URL=https://www.bitunix.com/register?vipCode=YOUR_CODE
NEXT_PUBLIC_BINANCE_AFFILIATE_URL=https://accounts.binance.com/register?ref=YOUR_CODE
NEXT_PUBLIC_BYBIT_AFFILIATE_URL=https://www.bybit.com/register?affiliate_id=YOUR_CODE
NEXT_PUBLIC_OKX_AFFILIATE_URL=https://www.okx.com/join/YOUR_CODE
NEXT_PUBLIC_KUCOIN_AFFILIATE_URL=https://www.kucoin.com/r/YOUR_CODE
NEXT_PUBLIC_GATE_AFFILIATE_URL=https://www.gate.io/signup?ref=YOUR_CODE

# === GUMROAD (for premium subscriptions) ===
NEXT_PUBLIC_GUMROAD_PRO_URL=https://mindvault34.gumroad.com/l/rwauqu
NEXT_PUBLIC_GUMROAD_ELITE_URL=https://mindvault34.gumroad.com/l/unetcl

# === OPTIONAL: Future integrations ===
